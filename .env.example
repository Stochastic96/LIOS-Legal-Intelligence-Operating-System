# Copy this file to .env and fill in your values.
# LIOS works fully offline; the only required value is LIOS_DB_PATH.

# ── Application ───────────────────────────────────────────────────────────────
LIOS_ENV=development          # development | production
LIOS_LOG_LEVEL=INFO
LIOS_API_HOST=0.0.0.0
LIOS_API_PORT=8000

# ── Database ──────────────────────────────────────────────────────────────────
LIOS_DB_PATH=data/db/lios.db

# ── Vector Store ─────────────────────────────────────────────────────────────
LIOS_VECTOR_STORE_PATH=data/vector_store
LIOS_EMBEDDING_MODEL=all-MiniLM-L6-v2   # local sentence-transformers model

# ── LLM Provider ─────────────────────────────────────────────────────────────
# "ollama" (default, fully local) or "openai"
LIOS_LLM_PROVIDER=ollama
LIOS_OLLAMA_BASE_URL=http://localhost:11434
LIOS_OLLAMA_MODEL=mistral

# Only needed when LIOS_LLM_PROVIDER=openai
LIOS_OPENAI_API_KEY=

# ── Knowledge Base ────────────────────────────────────────────────────────────
LIOS_REGULATIONS_PATH=data/regulations
LIOS_EURLEX_BASE_URL=https://eur-lex.europa.eu

# Decay: days before a regulation's freshness score starts falling
LIOS_DECAY_THRESHOLD_DAYS=365

# ── Consensus Engine ─────────────────────────────────────────────────────────
# Minimum fraction of agents that must agree (0.0–1.0)
LIOS_CONSENSUS_THRESHOLD=0.67
