# ── LLM Backend ──────────────────────────────────────────────────────────────
# Set LIOS_LLM_PROVIDER=azure to use Azure OpenAI (recommended for production)
# Set LIOS_LLM_PROVIDER=openai_compatible for local Ollama

LIOS_LLM_ENABLED=true
LIOS_LLM_PROVIDER=azure

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
# Get these from: Azure Portal → Your OpenAI resource → Keys and Endpoints
LIOS_AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE-NAME.openai.azure.com/
LIOS_AZURE_OPENAI_API_KEY=YOUR_32_CHAR_KEY_HERE
LIOS_AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
LIOS_AZURE_OPENAI_API_VERSION=2024-11-01-preview

# ── Local Ollama (only needed when LIOS_LLM_PROVIDER=openai_compatible) ──────
# LIOS_LLM_BASE_URL=http://localhost:11434/v1
# LIOS_LLM_MODEL=mistral:latest

# ── Security ──────────────────────────────────────────────────────────────────
# Required by mobile app X-API-Key header. Pick any strong random string.
LIOS_API_KEY=CHANGE_THIS_TO_A_STRONG_SECRET

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use * for development only.
# Production: set to your ngrok domain or Azure VM domain.
LIOS_CORS_ALLOWED_ORIGINS=https://nuptials-flame-steadily.ngrok-free.dev

# ── Chat store ────────────────────────────────────────────────────────────────
# jsonl = flat file (default, zero config)
# sqlite = local SQLite database
# postgres = Azure PostgreSQL (set LIOS_CHAT_STORE_DB_PATH to connection string)
LIOS_CHAT_STORE_BACKEND=jsonl
# LIOS_CHAT_STORE_DB_PATH=postgresql://user:password@your-pg-server:5432/lios

# ── Token budgets (optional — defaults are already set in config.py) ──────────
# LIOS_TOKEN_BUDGET_DEFAULT=800
# LIOS_TOKEN_BUDGET_ROADMAP=1500

# ── Misc ──────────────────────────────────────────────────────────────────────
LIOS_LOG_LEVEL=INFO
# LIOS_DEV_MODE=true
